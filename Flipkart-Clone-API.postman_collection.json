{
  "info": {
    "_postman_id": "7a5f0796-4cec-4c8a-b548-e30103b4574c",
    "name": "Flipkart Clone API",
    "description": "Postman collection for auth, products, cart, and orders APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Test Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "if (data.user && data.user.id) {",
                  "  pm.collectionVariables.set(\"userId\", data.user.id);",
                  "}",
                  "if (data.token) {",
                  "  pm.collectionVariables.set(\"authToken\", data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/test-login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "test-login"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Products (Search + Category)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products?search=phone&category=electronics",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products"
              ],
              "query": [
                {
                  "key": "search",
                  "value": "phone"
                },
                {
                  "key": "category",
                  "value": "electronics"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Product By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products",
                "{{productId}}"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Cart (Protected)",
      "item": [
        {
          "name": "Get Cart",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-user-id",
                "value": "{{userId}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/cart",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "cart"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Add To Cart",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 201\", function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "if (data.items && data.items.length > 0) {",
                  "  pm.collectionVariables.set(\"cartItemId\", data.items[0]._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-user-id",
                "value": "{{userId}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/cart",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "cart"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Update Cart Item Quantity",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "x-user-id",
                "value": "{{userId}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 2\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/cart/{{cartItemId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "cart",
                "{{cartItemId}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Delete Cart Item",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "x-user-id",
                "value": "{{userId}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/cart/{{cartItemId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "cart",
                "{{cartItemId}}"
              ]
            }
          },
          "response": []
        }
      ]
    },
